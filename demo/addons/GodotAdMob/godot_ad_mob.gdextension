[configuration]
entry_symbol = "godot_ad_mob_start"
compatibility_minimum = 4.2

[libraries]
ios = "res://addons/GodotAdMob/bin/GodotAdMob.xcframework"
linux.arm64 = "res://addons/GodotAdMob/bin/godot_ad_mob_stub.linux.arm64.so"
linux.x86_64 = "res://addons/GodotAdMob/bin/godot_ad_mob_stub.linux.x86_64.so"
macos.arm64 = "res://addons/GodotAdMob/bin/GodotAdMob.framework"
macos.x86_64 = "res://addons/GodotAdMob/bin/GodotAdMob_x64.framework"
windows.arm64 = "res://addons/GodotAdMob/bin/godot_ad_mob_stub.windows.arm64.dll"
windows.x86_64 = "res://addons/GodotAdMob/bin/godot_ad_mob_stub.windows.x86_64.dll"

[dependencies]
ios = { "res://addons/GodotApplePluginsRuntime/bin/SwiftGodotRuntime.xcframework": "" }
macos.arm64 = { "res://addons/GodotApplePluginsRuntime/bin/SwiftGodotRuntime.framework": "" }
macos.x86_64 = { "res://addons/GodotApplePluginsRuntime/bin/SwiftGodotRuntime_x64.framework": "" }
